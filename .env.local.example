# =============================================================================
# ENVIRONMENT VARIABLES - Personal Portfolio Website
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!
#
# Quick Start:
#   1. cp .env.local.example .env.local
#   2. Fill in the required values below
#   3. Restart your development server
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Site Configuration
# -----------------------------------------------------------------------------
# Your website's production URL (used for SEO, Open Graph, canonical URLs)
# Example: https://yourname.com or https://yourportfolio.vercel.app
NEXT_PUBLIC_SITE_URL=https://yourwebsite.com

# -----------------------------------------------------------------------------
# REQUIRED - Social Media URLs
# -----------------------------------------------------------------------------
# These are used in:
# - Footer social links
# - Contact page social links
# - Structured data (Schema.org Person)
# - Open Graph metadata

NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/yourusername

# -----------------------------------------------------------------------------
# OPTIONAL - Additional Social Media
# -----------------------------------------------------------------------------
# Add these if you want to include more social platforms
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourusername
# NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@yourusername
# NEXT_PUBLIC_DRIBBBLE_URL=https://dribbble.com/yourusername
# NEXT_PUBLIC_BEHANCE_URL=https://behance.net/yourusername

# -----------------------------------------------------------------------------
# REQUIRED - Google Analytics
# -----------------------------------------------------------------------------
# Get your GA4 Measurement ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
# Used for:
# - Page view tracking
# - Custom event tracking (resume downloads, newsletter signups)
# - User behavior analytics

NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# OPTIONAL - Google Search Console Verification
# -----------------------------------------------------------------------------
# Get verification code from https://search.google.com/search-console
# Used for:
# - Verifying site ownership
# - Submitting sitemaps
# - Monitoring search performance

# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# -----------------------------------------------------------------------------
# OPTIONAL - Other Search Engine Verifications
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code
# NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=your-yandex-verification-code

# -----------------------------------------------------------------------------
# REQUIRED - Contact Information
# -----------------------------------------------------------------------------
# Your professional email address
# Used in:
# - Contact page
# - Structured data (ContactPoint)
# - mailto: links

NEXT_PUBLIC_CONTACT_EMAIL=your.email@example.com

# -----------------------------------------------------------------------------
# OPTIONAL - Business/Location Information
# -----------------------------------------------------------------------------
# Used for local SEO and geo-targeting
# Get coordinates from: https://www.latlong.net/

NEXT_PUBLIC_BUSINESS_LATITUDE=37.7749
NEXT_PUBLIC_BUSINESS_LONGITUDE=-122.4194
NEXT_PUBLIC_BUSINESS_CITY=San Francisco
NEXT_PUBLIC_BUSINESS_STATE=CA
NEXT_PUBLIC_BUSINESS_COUNTRY=US

# -----------------------------------------------------------------------------
# NEWSLETTER SERVICE - Choose ONE of the following
# -----------------------------------------------------------------------------

# Option 1: Mailchimp
# Get credentials from: https://mailchimp.com/developer/
# MAILCHIMP_API_KEY=your_mailchimp_api_key_here
# MAILCHIMP_LIST_ID=your_mailchimp_list_id_here
# MAILCHIMP_DC=us1
# Note: DC (Data Center) is the part before .api.mailchimp.com in your API endpoint

# Option 2: ConvertKit
# Get credentials from: https://app.convertkit.com/account_settings/advanced_settings
# CONVERTKIT_API_KEY=your_convertkit_api_key_here
# CONVERTKIT_FORM_ID=your_convertkit_form_id_here

# Option 3: Buttondown
# Get API key from: https://buttondown.email/settings
# BUTTONDOWN_API_KEY=your_buttondown_api_key_here

# Option 4: Sendinblue (Brevo)
# Get API key from: https://account.sendinblue.com/advanced/api
# SENDINBLUE_API_KEY=your_sendinblue_api_key_here
# SENDINBLUE_LIST_ID=your_sendinblue_list_id_here

# Option 5: EmailOctopus
# Get credentials from: https://emailoctopus.com/api-documentation
# EMAILOCTOPUS_API_KEY=your_emailoctopus_api_key_here
# EMAILOCTOPUS_LIST_ID=your_emailoctopus_list_id_here

# -----------------------------------------------------------------------------
# OPTIONAL - Email Service (for contact form)
# -----------------------------------------------------------------------------
# If you want to handle contact form submissions via email service

# Option 1: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_TO_EMAIL=your.email@example.com

# Option 2: Resend
# RESEND_API_KEY=your_resend_api_key_here
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Option 3: Postmark
# POSTMARK_API_KEY=your_postmark_api_key_here
# POSTMARK_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# OPTIONAL - Database (if you add dynamic features)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# -----------------------------------------------------------------------------
# OPTIONAL - Authentication (if you add admin features)
# -----------------------------------------------------------------------------
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-random-secret-here
# Generate secret: openssl rand -base64 32

# -----------------------------------------------------------------------------
# OPTIONAL - CMS Integration
# -----------------------------------------------------------------------------
# If you integrate with a headless CMS for blog/projects

# Contentful
# CONTENTFUL_SPACE_ID=your_space_id
# CONTENTFUL_ACCESS_TOKEN=your_access_token
# CONTENTFUL_PREVIEW_ACCESS_TOKEN=your_preview_token

# Sanity
# NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=your_api_token

# Strapi
# STRAPI_API_URL=http://localhost:1337
# STRAPI_API_TOKEN=your_api_token

# -----------------------------------------------------------------------------
# OPTIONAL - Image/Media Services
# -----------------------------------------------------------------------------
# Cloudinary (for optimized image hosting)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Uploadcare
# NEXT_PUBLIC_UPLOADCARE_PUBLIC_KEY=your_public_key
# UPLOADCARE_SECRET_KEY=your_secret_key

# -----------------------------------------------------------------------------
# OPTIONAL - Error Tracking & Monitoring
# -----------------------------------------------------------------------------
# Sentry (for error tracking)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# LogRocket (for session replay)
# NEXT_PUBLIC_LOGROCKET_APP_ID=your_app_id/project_name

# -----------------------------------------------------------------------------
# OPTIONAL - Feature Flags
# -----------------------------------------------------------------------------
# Control feature availability without code changes
# NEXT_PUBLIC_ENABLE_NEWSLETTER=true
# NEXT_PUBLIC_ENABLE_RESUME_DOWNLOAD=true
# NEXT_PUBLIC_ENABLE_TESTIMONIALS=true
# NEXT_PUBLIC_ENABLE_ANNOUNCEMENTS=true

# -----------------------------------------------------------------------------
# DEVELOPMENT - Local Development Only
# -----------------------------------------------------------------------------
# These should NOT be set in production
# ANALYZE=true  # Set to analyze bundle size: ANALYZE=true npm run build
# SKIP_ENV_VALIDATION=true  # Skip environment variable validation

# =============================================================================
# NOTES
# =============================================================================
#
# Public vs Private Variables:
# - NEXT_PUBLIC_* variables are exposed to the browser
# - Variables without NEXT_PUBLIC_ are server-side only
# - Never put sensitive data in NEXT_PUBLIC_* variables
#
# Required vs Optional:
# - Required variables must be set for the site to work properly
# - Optional variables enable additional features
#
# Getting Started:
# 1. Set NEXT_PUBLIC_SITE_URL to your domain
# 2. Add your social media URLs
# 3. Set up Google Analytics (NEXT_PUBLIC_GA_ID)
# 4. Configure newsletter service (choose one option)
# 5. Add your contact email
#
# For detailed setup instructions, see:
# - /IMPLEMENTATION_SUMMARY.md
# - /SEO_ENHANCEMENTS.md
# - /README.md
#
# =============================================================================