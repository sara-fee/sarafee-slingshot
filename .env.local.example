# =============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SITE CONFIGURATION (Required for SEO)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://yourwebsite.com

# -----------------------------------------------------------------------------
# SOCIAL MEDIA LINKS (Required for Footer and SEO)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/yourusername

# -----------------------------------------------------------------------------
# GOOGLE ANALYTICS (Optional - for tracking)
# -----------------------------------------------------------------------------
# Get your GA4 Measurement ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# NEWSLETTER SERVICE (Required for newsletter subscription)
# -----------------------------------------------------------------------------
# Choose ONE of the following newsletter services:

# Option 1: Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_LIST_ID=your_mailchimp_list_id_here
MAILCHIMP_DC=us1
# Get from: https://mailchimp.com/developer/

# Option 2: ConvertKit
# CONVERTKIT_API_KEY=your_convertkit_api_key
# CONVERTKIT_FORM_ID=your_form_id
# Get from: https://app.convertkit.com/account/edit

# Option 3: Buttondown
# BUTTONDOWN_API_KEY=your_buttondown_api_key
# Get from: https://buttondown.email/settings

# -----------------------------------------------------------------------------
# INSTAGRAM FEED (Optional - for social media integration)
# -----------------------------------------------------------------------------
# Instagram Basic Display API
# Get from: https://developers.facebook.com/apps/
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Note: Instagram access tokens expire every 60 days and need to be refreshed
# Alternative: Use third-party services like Juicer.io or SnapWidget

# -----------------------------------------------------------------------------
# SUBSTACK FEED (Optional - for blog integration)
# -----------------------------------------------------------------------------
# Your Substack publication URL (without https://)
NEXT_PUBLIC_SUBSTACK_URL=yoursubstack.substack.com

# No API key needed - uses public RSS feed
# RSS feed is available at: https://yoursubstack.substack.com/feed

# -----------------------------------------------------------------------------
# PWA CONFIGURATION (Optional - for Progressive Web App)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Your Name Portfolio
NEXT_PUBLIC_APP_SHORT_NAME=Portfolio
NEXT_PUBLIC_APP_DESCRIPTION=Full Stack Developer Portfolio

# -----------------------------------------------------------------------------
# SEO VERIFICATION (Optional - for search engine verification)
# -----------------------------------------------------------------------------
# Google Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_verification_code

# Bing Webmaster Tools
# NEXT_PUBLIC_BING_VERIFICATION=your_bing_verification_code

# Yandex Webmaster
# NEXT_PUBLIC_YANDEX_VERIFICATION=your_yandex_verification_code

# -----------------------------------------------------------------------------
# CONTACT FORM (Optional - if using backend for contact form)
# -----------------------------------------------------------------------------
# If you want to send emails from contact form:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# CONTACT_EMAIL=your-email@example.com

# Alternative: Use services like SendGrid, Mailgun, or Resend
# SENDGRID_API_KEY=your_sendgrid_api_key
# RESEND_API_KEY=your_resend_api_key

# -----------------------------------------------------------------------------
# DEVELOPMENT (Optional)
# -----------------------------------------------------------------------------
# Set to 'development' or 'production'
NODE_ENV=development

# Enable/disable analytics in development
# NEXT_PUBLIC_ENABLE_ANALYTICS=false

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# - All NEXT_PUBLIC_* variables are exposed to the browser
# - Keep sensitive keys (API keys, tokens) without NEXT_PUBLIC_ prefix
# - Never commit .env.local to git (it's in .gitignore)
# - Use .env.local for local development
# - Use Vercel dashboard for production environment variables
# - Restart dev server after changing environment variables
# -----------------------------------------------------------------------------